{
  "name": "@maronn-oidc/sample-express-flyio",
  "version": "0.0.1",
  "private": true,
  "description": "Express sample app with OpenID Provider code generated by the CLI",
  "type": "module",
  "scripts": {
    "generate": "maronn-oidc generate express --output ./src/oidc-provider",
    "check:generated": "pnpm run generate && node scripts/check-generated.mjs",
    "build": "pnpm --filter @maronn-oidc/core build && tsc --noEmit && esbuild src/server.ts --bundle --platform=node --format=esm --target=node22 --external:express --outfile=dist/server.js --sourcemap",
    "start": "node dist/server.js",
    "launch": "pnpm run build && pnpm run start",
    "test": "pnpm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@maronn-oidc/core": "workspace:*"
  },
  "devDependencies": {
    "@maronn-oidc/cli": "workspace:*",
    "@types/express": "^5.0.5",
    "@types/node": "^25.2.2",
    "esbuild": "^0.25.12",
    "express": "^5.2.1",
    "typescript": "^5.7.2"
  }
}
