{
  "name": "@maronn-oidc/sample-nextjs-vercel",
  "version": "0.0.2",
  "private": true,
  "description": "Next.js sample app with OpenID Provider code generated by the CLI",
  "type": "module",
  "scripts": {
    "generate": "maronn-oidc generate nextjs --output ./src/app",
    "check:generated": "pnpm run generate && node scripts/check-generated.mjs",
    "build": "pnpm --filter @maronn-oidc/core build && next build",
    "start": "next start --hostname ${HOST:-127.0.0.1} --port ${PORT:-3010}",
    "launch": "pnpm run build && pnpm run start",
    "test": "pnpm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@maronn-oidc/core": "workspace:*"
  },
  "devDependencies": {
    "@maronn-oidc/cli": "workspace:*",
    "@types/node": "^25.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "next": "^16.2.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
