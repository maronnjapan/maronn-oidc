{
  "name": "@maronn-oidc/sample-hono",
  "version": "0.0.1",
  "private": true,
  "description": "Hono sample app with OpenID Provider code generated by the CLI",
  "type": "module",
  "scripts": {
    "generate": "maronn-oidc generate hono --output ./src/oidc-provider",
    "check:generated": "pnpm run generate && node scripts/check-generated.mjs",
    "build": "pnpm --filter @maronn-oidc/core build && tsc --noEmit && esbuild src/server.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/server.js --sourcemap",
    "start": "node dist/server.js",
    "test": "pnpm run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@maronn-oidc/core": "workspace:*"
  },
  "devDependencies": {
    "@maronn-oidc/cli": "workspace:*",
    "@types/node": "^26.1.1",
    "esbuild": "^0.25.12",
    "hono": "^4.12.25",
    "typescript": "^5.7.2"
  }
}
